---
import { ObjectDetailView } from "@fa-m8/astro-media-m8/default-ui";
import "../../scaffold/styles/media.css";

const { id } = Astro.params;

const config = {
  apiBase: import.meta.env.PUBLIC_FA_MEDIA_API_BASE,
  v1Base: import.meta.env.PUBLIC_FA_MEDIA_V1_BASE,
  legacyBase: import.meta.env.PUBLIC_FA_MEDIA_LEGACY_BASE,
  adminRole: import.meta.env.PUBLIC_FA_MEDIA_ADMIN_ROLE
};
---
{id ? <ObjectDetailView client:load config={config} objectId={id} libraryHref="../../media" /> : <p>Missing object id</p>}
